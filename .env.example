# ── Server ──────────────────────────────────────────

CLIENT_URL=        # allowed CORS origin
PORT=                               # Fastify server port

# ── Database ────────────────────────────────────────

DB_USER=
DB_PASSWORD=
DB_PORT=                            # internal Postgres port
DB_NAME=
DATABASE_URL=

# In-memory queue for batching DB writes

QUEUE_FLUSH_INTERVAL=2000               # ms — how often to flush queue to DB 
QUEUE_MAX_BATCH=20                      # max batch size before early flush

# ── Casts ────────────────────────────────────────────

VITE_MAX_LINE_LENGTH=25                     
VITE_MAX_LINES=3                         
VITE_SHRINK_DURATION=3000              # ms — new cast shrink animation
VITE_NEW_CAST_SIZE_MULT=16             # new cast initial size multiplier
BASE_FONT_SIZE=20                      # base font size for casts  
FONT_SIZE_VARIANCE=10                  # max random variance added to font size

# ── Void Visuals ─────────────────────────────────────

VITE_INITIAL_ZOOM=1                  # initial void zoom  (1 = 100%)
DRIFT_SPEED_MIN=2                      # min cast drift
DRIFT_SPEED_MAX=5                     # max cast drift

# ── UI Text ──────────────────────────────────────────
VITE_INPUT_PLACEHOLDER=into the void...

# ── Limits ───────────────────────────────────────────

RATE_LIMIT_PER_IP=10                      # max requests per IP per minute
RATE_LIMIT_GLOBAL=200                          # max requests globally per minute
VITE_IDLE_TIMEOUT=300000 # ms — time after which user is considered idle