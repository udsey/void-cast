# ── Server ──────────────────────────────────────────
CLIENT_URL=                             # allowed CORS origin e.g. http://localhost:5173
PORT=3000                               # Fastify server port

# ── Database ────────────────────────────────────────
DB_USER=                                # Postgres username
DB_PASSWORD=                            # Postgres password
DB_PORT=5432                            # internal Postgres port
DB_NAME=                                # Postgres database name
DATABASE_URL=                           # postgresql://user:password@localhost:5435/dbname

# ── Casts ────────────────────────────────────────────
CASTS_LIMIT=200                         # max casts returned from DB
VITE_MAX_LINE_LENGTH=35                      # max chars per line 
VITE_MAX_LINES=3                             # max lines per cast

# ── Client ──────────────────────────────────────────
VITE_API_URL=                           # backend URL e.g. http://localhost:3000


# ── Animation ───────────────────────────────────────
VITE_DRIFT_DURATION_MIN=36000           # ms — fastest drift speed
VITE_DRIFT_DURATION_MAX=64000           # ms — slowest drift speed
VITE_SHRINK_DURATION=3000              # ms — new cast shrink animation
VITE_NEW_CAST_SIZE_MULT=16             # new cast initial size multiplier
VITE_BASE_FONT_SIZE=20                 # base font size in px
VITE_FONT_SIZE_VARIANCE=20             # ± variance in px
VITE_INITIAL_ZOOM=0.3                  # initial zoom (1 = 100%)
VITE_BASE_SPREAD=2                     # base spread multiplier

# ── UI Text ──────────────────────────────────────────
VITE_INPUT_PLACEHOLDER=SCREAM into the void...
VITE_BUTTON_TEXT=release
VITE_BUTTON_TEXT_OVER_LIMIT=✗ too long

VITE_WORLD_SIZE=2000
VITE_WORLD_SCALE=100